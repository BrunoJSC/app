{
  "name": "stack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.28",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.22",
      "evlog": "^2.19.2",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.7",
      "@trpc/tanstack-react-query": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "@tanstack/react-form": "^1.28.0",
      "@tailwindcss/postcss": "^4.3.1",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.1",
      "@better-auth/expo": "1.6.22",
      "drizzle-orm": "^0.45.1",
      "@types/pg": "^8.16.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev -F native",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @stack/db",
    "db:studio": "turbo run db:studio -F @stack/db",
    "db:generate": "turbo run db:generate -F @stack/db",
    "db:migrate": "turbo run db:migrate -F @stack/db",
    "db:start": "turbo run db:start -F @stack/db",
    "db:watch": "turbo run db:watch -F @stack/db",
    "db:stop": "turbo run db:stop -F @stack/db",
    "db:down": "turbo run db:down -F @stack/db",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@stack/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@stack/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "latest",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}
